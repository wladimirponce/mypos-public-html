# ── Seguridad: bloquear acceso directo a archivos sensibles ─────────────
<FilesMatch "^\.(env|gitignore|gitkeep)$|^(composer\.(json|lock)|Dockerfile|apache\.conf|php\.ini)$">
    Require all denied
</FilesMatch>

RewriteEngine On

# Bloquear acceso directo a directorios internos
RewriteRule ^(src|vendor|storage|database)(/|$) - [F,L]

# JWT: preservar el header Authorization para que PHP pueda leerlo
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1

# Acceso directo a instalar.php (solo necesario en el primer despliegue,
# eliminar public/instalar.php del servidor una vez instalada la BD)
RewriteRule ^instalar\.php$ public/instalar.php [L]

# Reenviar todas las demás peticiones al router PHP
RewriteRule ^ public/index.php [QSA,L]
