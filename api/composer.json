{
  "name": "agentika/mypos-backend",
  "description": "Backend API REST para MyPOS - Administrador Punto de Venta",
  "type": "project",
  "autoload": {
    "psr-4": {
      "Mypos\\": "src/"
    }
  },
  "require": {
    "php": "^8.3",
    "firebase/php-jwt": "^6.10",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.12",
    "friendsofphp/php-cs-fixer": "^3.64"
  },
  "scripts": {
    "test": "phpunit",
    "test:smoke": "php ../tests/run_smoke_tests.php",
    "check:env": "php ../scripts/check_env.php",
    "lint": "php -l public/index.php",
    "analyse": "phpstan analyse src --level=max",
    "cs-fix": "php-cs-fixer fix src"
  }
}
