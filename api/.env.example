# Entorno de Produccion para MyPOS Backend
# Copiar a .env en la raiz del backend en el servidor productivo

APP_ENV=production
APP_DEBUG=false
APP_URL=https://www.mypos.cl/api
API_BASE_URL=https://www.mypos.cl
FRONTEND_URL=https://www.mypos.cl

# CORS
# En produccion es critico NO USAR *. Declarar dominios permitidos sin trailing slash
CORS_ALLOWED_ORIGINS=https://www.mypos.cl,https://mypos.cl

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_MAX_REQUESTS=10
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60

# Archivos y Logs
# Usar rutas absolutas o relativas desde el DOCUMENT_ROOT logico. 
# Si esta sobre cPanel, dejar estos relativos deberia escribir en el directorio 'storage' fuera del root publico.
STORAGE_PATH=storage
LOG_PATH=storage/logs/app.log
UPLOAD_MAX_MB=20
LOG_LEVEL=warning

# Base de datos
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mypos_prod
DB_USERNAME=usuario_bd
DB_PASSWORD=
DB_ROOT_PASSWORD=

# JWT
# Generar un string criptografico fuerte (Ej: php -r "echo bin2hex(random_bytes(32));")
JWT_SECRET=
JWT_TTL_MINUTES=1440

# DTE
DTE_SISTEMA_PATH=
DTE_MODE_DEFAULT=SIMULADO
DTE_REAL_ENABLED=false

# Gemini (IA)
# Si se desea habilitar, ingresar clave secreta aqui (NO en repositorios publicos ni en el frontend)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
